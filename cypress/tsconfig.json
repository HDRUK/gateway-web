{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "dom"],
        "module": "ESNext",
        "types": ["cypress", "node"],
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": false,
        "paths": {
            "@/*": ["../src/*"]
        }
    },
    "include": ["**/*.ts", "../cypress.config.ts"]
}
