    "scripts": {
        "start": "GENERATE_SOURCEMAP=false react-scripts start",
        "build": "DISABLE_ESLINT_PLUGIN=true react-scripts build",
        "test:watchAll": "cross-env NODE_ENV=test TZ=UTC jest --watchAll --env=jsdom --config=jest.config.json",
        "test:watch": "cross-env NODE_ENV=test TZ=UTC jest --watch --env=jsdom --config=jest.config.json",
        "test:ci": "cross-env NODE_ENV=test TZ=UTC jest --ci --runInBand --env=jsdom --config=jest.config.json",
        "test": "cross-env NODE_ENV=test TZ=UTC jest --env=jsdom --coverage --config=jest.config.json",
        "test-rtl": "cross-env NODE_ENV=test TZ=UTC jest --env=jsdom --testPathIgnorePatterns=/test/",
        "eject": "react-scripts eject",
        "snyk-protect": "snyk-protect",
        "prepare": "npm run snyk-protect",
        "lint": "eslint ./src --ext .js,.jsx",
        "lint:fix": "eslint ./src --ext .js,.jsx --fix",
        "prettier:write": "prettier --write \"./src/**/*.{js,jsx}\"",
        "storybook": "start-storybook -p 6006 -s public",
        "build-storybook": "build-storybook -s public",
        "serve": "npm run build && nodemon ./server.js",
        "cypress:open": "npx cypress open"
    },
    "eslintConfig": {
        "extends": "react-app",
        "overrides": [
            {
                "files": [
                    "**/*.stories.*"
                ],
                "rules": {
                    "import/no-anonymous-default-export": "off"
                }
            }
        ]
    },
